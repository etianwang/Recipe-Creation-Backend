# ========== 服务 ==========
PORT=3000
NODE_ENV=development
# 云托管：PORT=80，NEST_PORT=8080

# ========== 数据库 ==========
# 本地 MySQL
DATABASE_URL="mysql://root:CHANGE_ME@127.0.0.1:3306/recipe_assistant"
# 云托管也可用 MYSQL_*（cloud-start.js 自动拼 DATABASE_URL）：
# MYSQL_ADDRESS=10.x.x.x:3306
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=recipe_assistant

# ========== 鉴权 ==========
JWT_SECRET="change-me-to-random-string"
# 管理员 openid，逗号分隔（可审核用户提交食材）
ADMIN_OPENIDS=

# ========== 限流 ==========
API_RATE_TTL_MS=60000
API_RATE_LIMIT=60
AI_DAILY_QUOTA=20

# ========== 微信小程序登录 ==========
WECHAT_APPID=""
WECHAT_SECRET=""
# 仅开发且 NODE_ENV≠production：WECHAT_DEV_LOGIN=1，code 用 "dev:任意openid"
WECHAT_DEV_LOGIN=0

# ========== AI（生产必配 anthropic + 密钥）==========
AI_PROVIDER=anthropic
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_AUTH_TOKEN=""
# 兼容别名
ANTHROPIC_API_KEY=
AI_MODEL="claude-sonnet-4-6"
AI_TIMEOUT_MS=60000
# OpenAI 兼容（AI_PROVIDER=openai 时使用）
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1

# ========== 种子数据 ==========
RUN_SEED_ON_START=0
SEED_MINIMAL=1
SEED_INGREDIENTS=200
SEED_RECIPES=800
SEED_SUBSTITUTES=1500
SEED_SECRET="change-me-seed-secret"
# 生产 HTTP 灌种默认关闭；临时运维设 ENABLE_SEED_API=1
# ENABLE_SEED_API=0
SEED_TIMEOUT_MS=600000
MIGRATE_RETRIES=5

# ========== 云托管内部 ==========
# NEST_PORT=8080
