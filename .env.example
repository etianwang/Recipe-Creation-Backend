PORT=3000
# Local MySQL (docker compose) or 微信云托管 MySQL
# Cloud typical:
#   DATABASE_URL=mysql://root:PASSWORD@MYSQL_ADDRESS/recipe_assistant
# or rely on MYSQL_ADDRESS / MYSQL_USERNAME / MYSQL_PASSWORD (see scripts/cloud-start.sh)
DATABASE_URL="mysql://root:CHANGE_ME@127.0.0.1:3306/recipe_assistant"
JWT_SECRET="change-me"
API_RATE_TTL_MS=60000
API_RATE_LIMIT=60
AI_DAILY_QUOTA=20

# 微信小程序登录（jscode2session）
WECHAT_APPID=""
WECHAT_SECRET=""
# 本地无微信凭证时：WECHAT_DEV_LOGIN=1，code 用 "dev:任意openid"
WECHAT_DEV_LOGIN=0

# AI: fake | anthropic | openai | openai-compatible
AI_PROVIDER=anthropic
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_AUTH_TOKEN=""
AI_MODEL="claude-sonnet-4-6"
AI_TIMEOUT_MS=60000

# Optional OpenAI-compatible
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
