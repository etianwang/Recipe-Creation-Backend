{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "outDir": "dist/prisma",
    "rootDir": "prisma",
    "skipLibCheck": true,
    "strict": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["prisma/seed.ts"]
}
