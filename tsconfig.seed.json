{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "prisma/seed.ts",
    "prisma/seed-catalog.ts",
    "prisma/seed-ingredients-extended.ts",
    "prisma/seed-recipes-international.ts",
    "prisma/core-substitutes.ts",
    "src/common/food-safety.ts"
  ]
}
